@page "/ucne/ver-solicitud/{DocumentoId:int}"

<SessionGuard />

@inject SessionService session
@inject DocumentoService documentoService
@inject RegistradorService registradorService
@inject NavigationManager Navigation

<PageTitle>Detalles del Documento</PageTitle>

<div class="form-section">
    <div class="card shadow-lg">
        <div class="card-header text-center">
            <h4 class="card-title">
                <i class="bi bi-eye-fill me-2"></i> Detalles del Documento Académico
            </h4>
        </div>

        <div class="card-body">
            @if (documento == null)
            {
                <div class="text-center my-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3">Cargando información del documento...</p>
                </div>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>ID del Documento</strong></label>
                        <input class="form-control" value="@documento.DocumentoId" disabled />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><strong>Tipo de Documento</strong></label>
                        
                        @if (documento.TipoDocumentoId == 15 && !string.IsNullOrWhiteSpace(documento.DescripcionAdicional))
                        {
                            <input class="form-control"
                                value="@($"{documento.TipoDocumento?.Nombre} - {documento.DescripcionAdicional}")"
                                disabled />
                        }
                        else
                        {
                            <input class="form-control" value="@documento.TipoDocumento?.Nombre" disabled />
                        }
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><strong>Estudiante</strong></label>
                        <input class="form-control"
                               value="@($"{documento.Estudiante!.Nombres} {documento.Estudiante.Apellidos}")" disabled />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><strong>Carrera</strong></label>
                        <input class="form-control" value="@documento.Estudiante.Carrera" disabled />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label"><strong>Estado del Proceso</strong></label>
                        <input class="form-control" value="@documento.EstadoProceso" disabled />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label"><strong>Fecha de Solicitud</strong></label>
                        <input class="form-control" value="@documento.FechaSolicitudLocal.ToString("dd/MM/yyyy")" disabled />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label"><strong>Fecha de Finalización</strong></label>
                        <input class="form-control"
                               value="@(documento.FechaFinalizadoLocal?.ToString("dd/MM/yyyy") ?? "Pendiente")" disabled />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label"><strong>Fecha de Entrega</strong></label>
                        <input class="form-control"
                               value="@(documento.FechaEntregaLocal?.ToString("dd/MM/yyyy") ?? "Pendiente")" disabled />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(documento.ArchivoPdfRuta))
                    {
                        <div class="col-12 mt-3 text-center">
                            <a href="@documento.ArchivoPdfRuta"
                               class="btn btn-outline-primary me-2"
                               target="_blank">
                                <i class="bi bi-eye-fill me-2"></i> Ver PDF en GitHub
                            </a>

                            @if (!string.IsNullOrEmpty(documento.HashArchivo))
                            {
                                <p class="mt-3 text-muted small">
                                    <strong>Hash SHA256:</strong> @documento.HashArchivo
                                </p>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="col-12 text-center mt-3">
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                No se ha subido ningún archivo PDF.
                            </span>
                        </div>
                    }
                </div>

                <hr class="my-4" />

                <h5 class="text-center text-secondary mb-3">
                    <i class="bi bi-people-fill me-2"></i> Historial de Trabajo del Documento
                </h5>

                @if (documento.DocumentoRegistradores == null || !documento.DocumentoRegistradores.Any())
                {
                    <p class="text-center text-muted">No se ha registrado actividad en este documento.</p>
                }
                else
                {
                    <div class="border p-3 rounded">
                        <div class="table-responsive">
                            <table class="table align-middle text-center">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Registrador</th>
                                        <th>Correo</th>
                                        <th>Fecha de Trabajo</th>
                                        <th>Descripción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (registro, index) in documento.DocumentoRegistradores.Select((r, i) => (r, i + 1)))
                                    {
                                        <tr>
                                            <td>@index</td>
                                            <td>@($"{registro.Registrador!.Nombres} {registro.Registrador.Apellidos}")</td>
                                            <td>@registro.Registrador.Correo</td>
                                            <td>@registro.FechaTrabajoLocal.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@(string.IsNullOrWhiteSpace(registro.DescripcionTrabajo) 
                                                ? "Sin descripción" 
                                                : registro.DescripcionTrabajo)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="card-footer text-center">
            <a href="/ucne/registros" class="btn btn-secondary">
                <span class="bi bi-arrow-left me-2"></span> Volver
            </a>
        </div>
    </div>
</div>

@code {
    [Parameter] public int DocumentoId { get; set; }

    private Documento? documento;

    protected override async Task OnInitializedAsync()
    {
        documento = await documentoService.Buscar(DocumentoId);

        if (documento?.DocumentoRegistradores != null)
        {
            foreach (var registro in documento.DocumentoRegistradores)
            {
                registro.Registrador = await registradorService.BuscarPorId(registro.RegistradorId) ?? new();
            }
        }
    }
}
