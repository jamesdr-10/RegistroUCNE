@page "/ucne/registro-estudiantes"

<SessionGuard />

@inject SessionService session
@inject EstudianteService estudianteService
@inject NavigationManager Navigation
@inject DocumentoService documentoService
@inject IJSRuntime JS

<PageTitle>Consulta de Estudiantes</PageTitle>

<div class="registros-container">
    <div class="card shadow-lg">
        <div class="card-header text-center">
            <h5 class="card-title"><strong>Consulta de Estudiantes</strong></h5>
        </div>

        <div class="card-body">
            <div class="d-flex justify-content-md-end mb-3">
                <a href="/ucne/crear-estudiante" class="btn btn-primary me-2 bi bi-person-plus">
                    Crear Estudiante
                </a>

                <button class="btn btn-success bi bi-upload" @onclick="AbrirModalImportar">
                    Importar CSV
                </button>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="form-label"><strong>Buscar por nombre o apellido</strong></label>
                    <InputText class="form-control" placeholder="Ej: Juan Pérez" @bind-Value="filtroNombre" />
                </div>

                <div class="col-md-3">
                    <label class="form-label"><strong>Matrícula</strong></label>
                    <InputText class="form-control" placeholder="Ej: 2020-1234" @bind-Value="filtroMatricula" />
                </div>

                <div class="col-md-3">
                    <label class="form-label"><strong>Carrera</strong></label>
                    <InputText class="form-control" placeholder="Ej: Ingeniería" @bind-Value="filtroCarrera" />
                </div>

                <div class="col-md-1">
                    <label class="form-label"><strong>Egresado</strong></label>
                    <InputSelect class="form-select" @bind-Value="filtroEgresado">
                        <option value="">Todos</option>
                        <option value="true">Sí</option>
                        <option value="false">No</option>
                    </InputSelect>
                </div>

                <div class="col-md-2 d-flex align-items-end justify-content-md-end">
                    <button class="btn btn-secondary w-100" @onclick="LimpiarFiltros">
                        <i class="bi bi-x-circle"></i> Limpiar filtros
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr class="text-center">
                            <th>ID</th>
                            <th>Nombres</th>
                            <th>Apellidos</th>
                            <th>Matrícula</th>
                            <th>Carrera</th>
                            <th>Dirección</th>
                            <th>Correo</th>
                            <th>Egresado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!estudiantesFiltrados.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center">No se han encontrado estudiantes.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var estudiante in estudiantesPaginados)
                            {
                                <tr class="text-center">
                                    <td>@estudiante.EstudianteId</td>
                                    <td>@estudiante.Nombres</td>
                                    <td>@estudiante.Apellidos</td>
                                    <td>@estudiante.Matricula</td>
                                    <td>@estudiante.Carrera</td>
                                    <td>@estudiante.Direccion</td>
                                    <td>@estudiante.Correo</td>
                                    <td>@(estudiante.EsEgresado ? "✅" : "❌")</td>
                                    <td>
                                        <div class="d-flex justify-content-center">
                                            <a href="/ucne/editar-estudiante/@estudiante.EstudianteId" 
                                                    class="btn btn-edit btn-sm" 
                                                    title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            <button type="button" class="btn btn-danger btn-sm"
                                                    title="Eliminar"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modalEliminar"
                                                    @onclick="@(() => SeleccionarEstudiante(estudiante))">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPaginas > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div>
                        <small>Mostrando @(((paginaActual - 1) * tamanoPagina) + 1)
                            -
                            @(Math.Min(paginaActual * tamanoPagina, estudiantesFiltrados.Count()))
                            de @estudiantesFiltrados.Count() registros</small>
                    </div>

                    <nav>
                        <ul class="pagination mb-0">
                            <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="PrimeraPagina">« Primera</button>
                            </li>
                            <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="PaginaAnterior">‹ Anterior</button>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link">Página @paginaActual de @totalPaginas</span>
                            </li>
                            <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                <button class="page-link" @onclick="PaginaSiguiente">Siguiente ›</button>
                            </li>
                            <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                <button class="page-link" @onclick="UltimaPagina">Última »</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMensaje))
            {
                <div class="error-message-container">
                    <div class="error-message">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        @errorMensaje
                    </div>
                </div>
            }
        </div>

        <div class="card-footer text-muted">
            <small>Total de estudiantes: @estudiantesFiltrados.Count()</small>
        </div>
    </div>
</div>

<!-- Modal de Importación CSV -->
@if (mostrarModalImportar)
{
    <div class="modalimporte-container">
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-success">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title">
                            <i class="bi bi-upload me-2"></i> Importar Estudiantes desde CSV
                        </h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalImportar"></button>
                    </div>

                    <div class="modal-body">
                        <p>
                            El archivo CSV debe contener el siguiente encabezado (en este orden):<br />
                            <code>Matricula,Nombres,Apellidos,Direccion,Correo,Carrera,EsEgresado</code>
                        </p>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <InputFile OnChange="ProcesarArchivoCsv" accept=".csv" />

                            <button class="btn btn-outline-primary btn-sm"
                                    @onclick="DescargarPlantilla"
                                    data-bs-toggle="tooltip"
                                    data-bs-placement="top"
                                    title="Descargar un ejemplo CSV con el formato correcto">
                                <i class="bi bi-file-earmark-arrow-down"></i> Descargar plantilla
                            </button>
                        </div>

                        @if (isImportando)
                        {
                            <div class="mt-3">
                                <div class="progress">
                                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                                        role="progressbar"
                                        style="width: @progreso%">
                                        @progreso%
                                    </div>
                                </div>
                                <p class="mt-2 text-center">
                                    Procesando @registrosImportados de @totalRegistros registros...
                                </p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(resultadoImportacion))
                        {
                            <div class="alert alert-info mt-3">@resultadoImportacion</div>
                        }
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarModalImportar">
                            <i class="bi bi-x-circle"></i> Cerrar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de eliminación -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Está seguro de que desea eliminar al siguiente estudiante?</p>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><strong>ID:</strong> <span class="badge bg-secondary">@estudianteSeleccionado?.EstudianteId</span></li>
                    <li class="list-group-item"><strong>Nombres:</strong> <span class="badge bg-primary">@estudianteSeleccionado?.Nombres</span></li>
                    <li class="list-group-item"><strong>Apellidos:</strong> <span class="badge bg-primary">@estudianteSeleccionado?.Apellidos</span></li>
                    <li class="list-group-item"><strong>Matrícula:</strong> <span class="badge bg-info">@estudianteSeleccionado?.Matricula</span></li>
                    <li class="list-group-item"><strong>Carrera:</strong> <span class="badge bg-success">@estudianteSeleccionado?.Carrera</span></li>
                </ul>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal" @onclick="Eliminar">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Estudiante> estudiantes = new();
    private Estudiante? estudianteSeleccionado;

    private string? errorMensaje;

    private string filtroNombre = "";
    private string filtroMatricula = "";
    private string filtroCarrera = "";
    private string filtroEgresado = "";

    private bool mostrarModalImportar = false;
    private bool isImportando = false;
    private int totalRegistros = 0;
    private int registrosImportados = 0;
    private int progreso => totalRegistros == 0 ? 0 : (int)((double)registrosImportados / totalRegistros * 100);
    private string resultadoImportacion = string.Empty;

    private int paginaActual = 1;
    private int tamanoPagina = 10;
    private int totalPaginas => (int)Math.Ceiling((double)estudiantesFiltrados.Count() / tamanoPagina);

    private IEnumerable<Estudiante> estudiantesFiltrados => estudiantes
        .Where(e =>
            (string.IsNullOrWhiteSpace(filtroNombre) ||
                $"{e.Nombres} {e.Apellidos}".Contains(filtroNombre, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(filtroMatricula) ||
                e.Matricula.Contains(filtroMatricula, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(filtroCarrera) ||
                e.Carrera.Contains(filtroCarrera, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(filtroEgresado) ||
                (filtroEgresado == "true" && e.EsEgresado) ||
                (filtroEgresado == "false" && !e.EsEgresado))
        )
        .OrderBy(e => e.Nombres);

    private IEnumerable<Estudiante> estudiantesPaginados => estudiantesFiltrados
        .Skip((paginaActual - 1) * tamanoPagina)
        .Take(tamanoPagina);

    protected override async Task OnInitializedAsync()
    {
        estudiantes = await estudianteService.Listar(e => e.Activo);
    }

    private void AbrirModalImportar() 
    {
        resultadoImportacion = string.Empty;
        mostrarModalImportar = true;
    }

    private void CerrarModalImportar()
    {
        mostrarModalImportar = false;
    }

    private async Task ProcesarArchivoCsv(InputFileChangeEventArgs e)
    {
        resultadoImportacion = string.Empty;
        isImportando = true;
        registrosImportados = 0;

        var archivo = e.File;
        using var stream = archivo.OpenReadStream(10_000_000);
        using var reader = new StreamReader(stream);

        var lineas = new List<string>();
        string? linea;
        bool primera = true;

        while ((linea = await reader.ReadLineAsync()) != null)
        {
            if (primera)
            {
                primera = false;
                continue;
            }

            if (!string.IsNullOrWhiteSpace(linea))
                lineas.Add(linea);
        }

        totalRegistros = lineas.Count;

        var errores = new List<string>();

        foreach (var (l, index) in lineas.Select((v, i) => (v, i + 2)))
        {
            var campos = l.Split(',');
            if (campos.Length < 7)
            {
                errores.Add($"❌ Línea {index}: número de columnas inválido.");
                continue;
            }

            var estudiante = new Estudiante
            {
                Matricula = campos[0].Trim(),
                Nombres = campos[1].Trim(),
                Apellidos = campos[2].Trim(),
                Direccion = campos[3].Trim(),
                Correo = campos[4].Trim(),
                Carrera = campos[5].Trim(),
                EsEgresado = bool.TryParse(campos[6].Trim(), out var egresado) && egresado
            };

            var context = new ValidationContext(estudiante);
            var results = new List<ValidationResult>();

            if (!Validator.TryValidateObject(estudiante, context, results, true))
            {
                var mensajes = string.Join("\n", results.Select(r => r.ErrorMessage));
                errores.Add($"❌ Línea {index}: {mensajes}");
                continue;
            }

            try
            {
                await estudianteService.Guardar(estudiante);
                registrosImportados++;
            }
            catch (Exception ex)
            {
                errores.Add($"⚠️ Línea {index}: Error al guardar ({ex.Message})");
            }

            StateHasChanged();
            await Task.Delay(100);
        }

        isImportando = false;

        if (errores.Count == 0)
        {
            resultadoImportacion = $"✅ Se importaron correctamente {registrosImportados} estudiantes.";
        }
        else
        {
            resultadoImportacion = $"⚠️ Se importaron {registrosImportados} estudiantes, pero hubo {errores.Count} errores:\n\n" +
                                string.Join("\n", errores.Take(10)) +
                                (errores.Count > 10 ? $"\n... y {errores.Count - 10} más." : "");
        }

        estudiantes = await estudianteService.Listar(e => e.Activo == true);
        paginaActual = 1;
    }

    private async Task DescargarPlantilla()
    {
        var csv = "\uFEFF" +
                  "Matricula,Nombres,Apellidos,Direccion,Correo,Carrera,EsEgresado\n" +
                  "2025-0001,Juan,Pérez Gómez,Calle Duarte #12,jperez@ucne.edu.do,Ingeniería en Software,false\n" +
                  "2025-0002,Ana,Gómez Castillo,Calle Sánchez #45,agomez@ucne.edu.do,Contabilidad,true\n";

        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync(
            "BlazorDownloadFile",
            "plantilla_estudiantes.csv",
            "text/csv;charset=utf-8",
            base64
        );
    }

    private async Task Eliminar()
    {
        errorMensaje = null;

        if (estudianteSeleccionado != null && await estudianteService.Deshabilitar(estudianteSeleccionado.EstudianteId))
        {
            foreach (var documento in estudianteSeleccionado.Documentos)
            {
                await documentoService.Deshabilitar(documento.DocumentoId);
            }

            estudiantes = await estudianteService.Listar(e => e.Activo == true);
            estudianteSeleccionado = null;
        }
        else
        {
            errorMensaje = "Error al eliminar el estudiante. Intente nuevamente.";
        }
    }

    private void SeleccionarEstudiante(Estudiante estudiante)
    {
        estudianteSeleccionado = estudiante;
    }

    private void LimpiarFiltros()
    {
        filtroNombre = "";
        filtroMatricula = "";
        filtroCarrera = "";
        filtroEgresado = "";
        paginaActual = 1;
    }

    private void PrimeraPagina() => paginaActual = 1;
    private void PaginaAnterior() { if (paginaActual > 1) paginaActual--; }
    private void PaginaSiguiente() { if (paginaActual < totalPaginas) paginaActual++; }
    private void UltimaPagina() => paginaActual = totalPaginas;
}
