@page "/ucne/editar-estudiante/{EstudianteId:int}"

<SessionGuard />

@inject SessionService session
@inject EstudianteService estudianteService
@inject RegistradorService registradorService
@inject NavigationManager Navigation

<PageTitle>Editar Estudiante</PageTitle>
<EditForm Model="estudiante" OnValidSubmit="MostrarModalConfirmacion">
    <DataAnnotationsValidator />

    <div class="form-section">
        <div class="card shadow-lg">
            <div class="card-header">
                <h4 class="card-title"><strong>Editar Estudiante</strong></h4>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label"><strong>Nombres</strong></label>
                    <InputText class="form-control" @bind-Value="estudiante.Nombres" placeholder="Ingrese los nombres" />
                    <ValidationMessage For="(() => estudiante.Nombres)" />
                </div>

                <div class="mb-3">
                    <label class="form-label"><strong>Apellidos</strong></label>
                    <InputText class="form-control" @bind-Value="estudiante.Apellidos" placeholder="Ingrese los apellidos" />
                    <ValidationMessage For="(() => estudiante.Apellidos)" />
                </div>

                <div class="mb-3">
                    <label class="form-label"><strong>Dirección</strong></label>
                    <InputText class="form-control" @bind-Value="estudiante.Direccion" placeholder="Ingrese la dirección" />
                    <ValidationMessage For="(() => estudiante.Direccion)" />
                </div>

                <div class="mb-3">
                    <label class="form-label"><strong>Correo</strong></label>
                    <InputText class="form-control" @bind-Value="estudiante.Correo" placeholder="Ingrese el correo" />
                    <ValidationMessage For="(() => estudiante.Correo)" />
                </div>

                <div class="mb-3">
                    <label class="form-label"><strong>Matrícula</strong></label>
                    <InputText class="form-control" @bind-Value="estudiante.Matricula" placeholder="Ingrese la matrícula" />
                    <ValidationMessage For="(() => estudiante.Matricula)" />
                </div>

                <div class="mb-3">
                    <label class="form-label"><strong>Carrera</strong></label>
                    <InputText class="form-control" @bind-Value="estudiante.Carrera" placeholder="Ingrese la carrera" />
                    <ValidationMessage For="(() => estudiante.Carrera)" />
                </div>

                <div class="form-check mb-3">
                    <InputCheckbox class="form-check-input" @bind-Value="estudiante.EsEgresado" />
                    <label class="form-check-label">Es Egresado</label>
                </div>

                @if (!string.IsNullOrEmpty(errorMensaje))
                {
                    <div class="error-message-container">
                        <div class="error-message">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            @errorMensaje
                        </div>
                    </div>
                }
            </div>

            <div class="card-footer text-center">
                <a href="/ucne/registro-estudiantes" class="btn btn-secondary me-2">
                    <span class="bi bi-arrow-left me-2"></span> Volver
                </a>

                <button class="btn btn-success"
                        type="submit"
                        disabled="@(isLoading || string.IsNullOrWhiteSpace(estudiante.Nombres)
                                              || string.IsNullOrWhiteSpace(estudiante.Apellidos)
                                              || string.IsNullOrWhiteSpace(estudiante.Direccion)
                                              || string.IsNullOrWhiteSpace(estudiante.Matricula)
                                              || string.IsNullOrWhiteSpace(estudiante.Correo)
                                              || string.IsNullOrWhiteSpace(estudiante.Carrera))">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span class="bi bi-save me-2"></span>
                        <span>Guardar</span>
                    }
                </button>
            </div>
        </div>
    </div>
</EditForm>

@if (mostrarModalConfirmacion)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-success">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-shield-lock-fill me-2"></i> Confirmar Edición
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalConfirmacion"></button>
                </div>

                <div class="modal-body">
                    <p>Para confirmar la edición, ingrese su contraseña: </p>

                    <div class="mb-3">
                        <label class="form-label"><strong>Contraseña</strong></label>
                        <input type="password" class="form-control" @bind="passwordConfirmacion" placeholder="Ingrese su contraseña" />
                    </div>

                    @if (!string.IsNullOrEmpty(errorConfirmacion))
                    {
                        <div class="text-danger">
                            <i class="bi bi-exclamation-circle me-2"></i>@errorConfirmacion
                        </div>
                    }
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModalConfirmacion">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                    <button type="button" class="btn btn-success" @onclick="ConfirmarGuardar">
                        <i class="bi bi-check-circle"></i> Confirmar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int EstudianteId { get; set; }

    private Registrador registrador = new();
    private Estudiante estudiante = new();

    private string errorMensaje = string.Empty;
    private bool isLoading = false;

    private bool mostrarModalConfirmacion = false;
    private string passwordConfirmacion = string.Empty;
    private string errorConfirmacion = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (EstudianteId > 0)
        {
            estudiante = await estudianteService.Buscar(EstudianteId) ?? new();
            registrador = await registradorService.BuscarPorId(session.RegistradorId) ?? new();
        }
    }

    private void MostrarModalConfirmacion()
    {
        errorConfirmacion = string.Empty;
        passwordConfirmacion = string.Empty;
        mostrarModalConfirmacion = true;
    }

    private void CerrarModalConfirmacion()
    {
        mostrarModalConfirmacion = false;
    }

    private async Task ConfirmarGuardar()
    {
        errorMensaje = string.Empty;
        errorConfirmacion = string.Empty;

        if (BCrypt.Net.BCrypt.Verify(passwordConfirmacion, registrador.Contrasena))
        {
            errorConfirmacion = "La contraseña no coincide.";
            return;
        }

        isLoading = true;

        if (await estudianteService.Guardar(estudiante))
        {
            mostrarModalConfirmacion = false;
            Navigation.NavigateTo("/ucne/registro-estudiantes");
        }
        else
        {
            mostrarModalConfirmacion = false;
            errorMensaje = "Error al guardar el estudiante. Intente nuevamente.";
            isLoading = false;
        }
    }
}
