@page "/ucne/registro-registradores"

<SessionGuard />

@inject SessionService session
@inject RegistradorService registradorService
@inject NavigationManager Navigation

<PageTitle>Consulta de Registradores</PageTitle>

<div class="registros-container">
    <div class="card shadow-lg">
        <div class="card-header text-center">
            <h5 class="card-title"><strong>Consulta de Registradores</strong></h5>
        </div>

        <div class="card-body">
            <div class="d-flex justify-content-md-end mb-3">
                <a href="/ucne/crear-registrador" class="btn btn-primary bi bi-person-plus">
                    Crear Registrador
                </a>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-3">
                    <label class="form-label"><strong>Buscar por nombre o apellido</strong></label>
                    <InputText class="form-control" placeholder="Ej: Juan Pérez" @bind-Value="filtroNombre" />
                </div>

                <div class="col-md-3">
                    <label class="form-label"><strong>Buscar por correo</strong></label>
                    <InputText class="form-control" placeholder="Ej: ejemplo@ucne.edu.do" @bind-Value="filtroCorreo" />
                </div>

                <div class="col-md-3">
                    <label class="form-label"><strong>Buscar por usuario</strong></label>
                    <InputText class="form-control" placeholder="Ej: jlopez" @bind-Value="filtroUsuario" />
                </div>

                <div class="col-md-3 d-flex align-items-end justify-content-md-end">
                    <button class="btn btn-secondary w-100" @onclick="LimpiarFiltros">
                        <i class="bi bi-x-circle"></i> Limpiar filtros
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr class="text-center">
                            <th>ID</th>
                            <th>Nombres</th>
                            <th>Apellidos</th>
                            <th>Dirección</th>
                            <th>Correo</th>
                            <th>Nombre de Usuario</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!registradoresFiltrados.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center">No se han encontrado registradores.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var registrador in registradoresPaginados)
                            {
                                <tr class="text-center">
                                    <td>@registrador.RegistradorId</td>
                                    <td>@registrador.Nombres</td>
                                    <td>@registrador.Apellidos</td>
                                    <td>@registrador.Direccion</td>
                                    <td>@registrador.Correo</td>
                                    <td>@registrador.NombreUsuario</td>
                                    <td>
                                        <div class="d-flex justify-content-center">
                                            <a href="/ucne/editar-registrador/@registrador.RegistradorId"
                                                class="btn btn-edit btn-sm"
                                                title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            <button type="button"
                                                    class="btn btn-danger btn-sm"
                                                    title="Eliminar"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modalEliminar"
                                                    @onclick="@(() => SeleccionarRegistrador(registrador))"
                                                    disabled="@(registrador.RegistradorId == session.RegistradorId)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPaginas > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div>
                        <small>Mostrando @(((paginaActual - 1) * tamanoPagina) + 1)
                            -
                            @(Math.Min(paginaActual * tamanoPagina, registradoresFiltrados.Count()))
                            de @registradoresFiltrados.Count() registros</small>
                    </div>

                    <nav>
                        <ul class="pagination mb-0">
                            <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="PrimeraPagina">« Primera</button>
                            </li>
                            <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="PaginaAnterior">‹ Anterior</button>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link">Página @paginaActual de @totalPaginas</span>
                            </li>
                            <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                <button class="page-link" @onclick="PaginaSiguiente">Siguiente ›</button>
                            </li>
                            <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                <button class="page-link" @onclick="UltimaPagina">Última »</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMensaje))
            {
                <div class="error-message-container mt-3">
                    <div class="error-message">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        @errorMensaje
                    </div>
                </div>
            }
        </div>

        <div class="card-footer text-muted">
            <small>Total de registradores: @registradoresFiltrados.Count()</small>
        </div>
    </div>
</div>

<!-- Modal eliminación -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Está seguro de que desea eliminar al siguiente registrador?</p>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><strong>ID:</strong> <span class="badge bg-secondary">@registradorSeleccionado?.RegistradorId</span></li>
                    <li class="list-group-item"><strong>Nombres:</strong> <span class="badge bg-primary">@registradorSeleccionado?.Nombres</span></li>
                    <li class="list-group-item"><strong>Apellidos:</strong> <span class="badge bg-primary">@registradorSeleccionado?.Apellidos</span></li>
                    <li class="list-group-item"><strong>Correo:</strong> <span class="badge bg-success">@registradorSeleccionado?.Correo</span></li>
                    <li class="list-group-item"><strong>Usuario:</strong> <span class="badge bg-info">@registradorSeleccionado?.NombreUsuario</span></li>
                </ul>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal" @onclick="Eliminar">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Registrador> registradores = new();
    private Registrador? registradorSeleccionado;

    private string? errorMensaje;

    private string filtroNombre = "";
    private string filtroCorreo = "";
    private string filtroUsuario = "";

    private int paginaActual = 1;
    private int tamanoPagina = 10;
    private int totalPaginas => (int)Math.Ceiling((double)registradoresFiltrados.Count() / tamanoPagina);

    private IEnumerable<Registrador> registradoresFiltrados => registradores
        .Where(r =>
            (string.IsNullOrWhiteSpace(filtroNombre) ||
                $"{r.Nombres} {r.Apellidos}".Contains(filtroNombre, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(filtroCorreo) ||
                r.Correo.Contains(filtroCorreo, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(filtroUsuario) ||
                r.NombreUsuario.Contains(filtroUsuario, StringComparison.OrdinalIgnoreCase))
        )
        .OrderBy(r => r.Nombres);

    private IEnumerable<Registrador> registradoresPaginados => registradoresFiltrados
        .Skip((paginaActual - 1) * tamanoPagina)
        .Take(tamanoPagina);

    protected override async Task OnInitializedAsync()
    {
        registradores = await registradorService.Listar(r => r.Activo);
    }

    private async Task Eliminar()
    {
        errorMensaje = null;

        if (registradorSeleccionado != null && await registradorService.Deshabilitar(registradorSeleccionado.RegistradorId))
        {
            registradores = await registradorService.Listar(r => r.Activo);
            registradorSeleccionado = null;
        }
        else
        {
            errorMensaje = "Error al eliminar el registrador. Intente nuevamente.";
        }
    }

    private void SeleccionarRegistrador(Registrador registrador)
    {
        registradorSeleccionado = registrador;
    }

    private void LimpiarFiltros()
    {
        filtroNombre = "";
        filtroCorreo = "";
        filtroUsuario = "";
        paginaActual = 1;
    }

    private void PrimeraPagina() => paginaActual = 1;
    private void PaginaAnterior() { if (paginaActual > 1) paginaActual--; }
    private void PaginaSiguiente() { if (paginaActual < totalPaginas) paginaActual++; }
    private void UltimaPagina() => paginaActual = totalPaginas;
}
